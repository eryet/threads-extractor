{
  "manifest_version": 3,
  "name": "Threads Extractor",
  "version": "0.14.2",
  "description": "Grab your saved posts, liked posts, feeds and profiles from Threads into a local dashboard. Export JSON/CSV/Markdown. 100% local.",
  "minimum_chrome_version": "111",
  "permissions": ["storage", "downloads", "alarms"],
  "host_permissions": [
    "https://www.threads.com/*",
    "https://threads.com/*"
  ],
  "background": { "service_worker": "sw.js" },
  "action": { "default_popup": "popup.html", "default_title": "Threads Saved Extractor" },
  "content_scripts": [
    {
      "matches": ["https://www.threads.com/*", "https://threads.com/*"],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.threads.com/*", "https://threads.com/*"],
      "js": ["lib/i18n.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
